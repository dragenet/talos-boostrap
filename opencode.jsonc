{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md", "CLAUDE.md"],
  "model": "openai/gpt-5.4-mini-fast",
  "default_agent": "build",
  "share": "disabled",
  "small_model": "opencode-go/minimax-m3",
  "skills": {
    "paths": [".opencode/skills"]
  },
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "infra/talos/secrets/**": "deny",
      "*.sops.decrypted.*": "deny"
    },
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "edit": "ask",
    "bash": {
      "*": "ask",
      "* || *": "allow",
      "* && *": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git branch*": "allow",
      "git stash list*": "allow",
      "opencode models*": "allow",
      "graphify query*": "allow",
      "graphify explain*": "allow",
      "graphify path*": "allow",
      "graphify update*": "allow",
      "graphify status*": "allow",
      "ansible-lint*": "allow",
      "kustomize build*": "allow",
      "flux build*": "allow",
      "helm lint*": "allow",
      "helm template*": "allow",
      "yamllint*": "allow",
      "ansible-playbook *": "ask",
      "sops *": "ask",
      "hcloud *": "ask",
      "talosctl *": "ask",
      "kubectl *": "ask",
      "flux reconcile *": "ask",
      "git add*": "ask",
      "git commit*": "ask",
      "git push*": "deny",
      "git reset --hard*": "deny",
      "git checkout --*": "deny",
      "rm -rf *": "deny"
    },
    "external_directory": {
      "*": "ask",
      "~/Projects/infra/kube1/**": "allow"
    },
    "task": {
      "*": "ask"
    },
    "skill": {
      "*": "allow"
    },
    "webfetch": "allow",
    "websearch": "allow",
    "question": "allow",
    "todowrite": "allow",
    "doom_loop": "ask"
  },
  "agent": {
    "build": {
      "prompt": "You are the kube1 OpenCode orchestrator. Keep your always-on behavior simple: delegate by default, use graphify first for repo questions, and prefer project subagents over broad work in the main session. Prefer graphify every time you need repo context, not just at the start. For any task beyond trivial, load the `kube1-orchestration` skill. Use `task-planner` only when durable planning is clearly needed. If web/external context is needed, call `web-fast-context`. Prefer multiple small, focused subagent tasks in parallel over one large bundled subagent task when the work can be split safely. For implementation, launch as many non-conflicting implementor agents in parallel as the plan safely allows, each with a simple task scoped to one domain/context. Never hand a whole broad plan step to one implementor when it includes separable contexts; split it first. Do not use `Read` or `Glob` in the main session until graphify has narrowed the files for that specific question. Prefer opencode LSP tools for semantic navigation/refactors when available. Preserve dependencies. Do not use `explore` for kube1 repo questions.",
      "permission": {
        "bash": {
          "*": "ask",
          "graphify query*": "allow",
          "graphify explain*": "allow",
          "graphify path*": "allow",
          "graphify update*": "allow",
          "graphify status*": "allow",
          "echo *": "deny",
          "rg *": "deny",
          "* rg *": "deny",
          "grep *": "deny",
          "find *": "deny",
          "* | head*": "deny",
          "*&& rg *": "deny"
        },
        "task": {
          "*": "deny",
          "task-planner": "allow",
          "web-fast-context": "allow",
          "ansible-implementor": "allow",
          "k8s-implementor": "allow",
          "ansible-reviewer": "allow",
          "k8s-reviewer": "allow",
          "docs-writer": "allow",
          "adr-writer": "allow",
          "report-writer": "allow",
          "git": "allow",
          "general": "ask"
        }
      }
    },
    "plan": {
      "prompt": "You are the kube1 planning orchestrator. Stay read-only. Use `kube1-orchestration` for routing rules. Use `task-planner` when a durable multi-step plan is needed. Keep the primary session small: every time you need repo context, use graphify first. Do not use `Read` or `Glob` in the main session until graphify has narrowed the files for that specific question. Prefer opencode LSP tools for semantic navigation when available. Use `web-fast-context` for official docs/external facts. Parallelize independent context/review subagents when possible. Do not implement changes in plan mode and do not use `explore` for kube1 repo questions.",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "graphify query*": "allow",
          "graphify explain*": "allow",
          "graphify path*": "allow",
          "graphify update*": "allow",
          "graphify status*": "allow",
          "echo *": "deny",
          "rg *": "deny",
          "* rg *": "deny",
          "grep *": "deny",
          "find *": "deny",
          "* | head*": "deny",
          "*&& rg *": "deny"
        },
        "task": {
          "*": "deny",
          "task-planner": "allow",
          "web-fast-context": "allow",
          "ansible-reviewer": "allow",
          "k8s-reviewer": "allow",
          "git": "allow"
        }
      }
    },
    "explore": {
      "disable": true
    }
  },
  "watcher": {
    "ignore": ["graphify-out/**", "infra/ansible/.collections/**", "infra/talos/secrets/**"]
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 6
  }
}
