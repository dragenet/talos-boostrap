{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md", "CLAUDE.md"],
  "model": "openai/gpt-5.4-mini-fast",
  "default_agent": "build",
  "share": "disabled",
  "small_model": "opencode-go/minimax-m3",
  "skills": {
    "paths": [".opencode/skills"]
  },
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "infra/talos/secrets/**": "deny",
      "*.sops.decrypted.*": "deny"
    },
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "edit": "ask",
    "bash": {
      "*": "ask",
      "* || *": "allow",
      "* && *": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git branch*": "allow",
      "git stash list*": "allow",
      "opencode models*": "allow",
      "graphify query*": "allow",
      "graphify explain*": "allow",
      "graphify path*": "allow",
      "graphify update*": "allow",
      "graphify status*": "allow",
      "ansible-lint*": "allow",
      "kustomize build*": "allow",
      "flux build*": "allow",
      "helm lint*": "allow",
      "helm template*": "allow",
      "yamllint*": "allow",
      "ansible-playbook *": "ask",
      "sops *": "ask",
      "hcloud *": "ask",
      "talosctl *": "ask",
      "kubectl *": "ask",
      "flux reconcile *": "ask",
      "git add*": "ask",
      "git commit*": "ask",
      "git push*": "deny",
      "git reset --hard*": "deny",
      "git checkout --*": "deny",
      "rm -rf *": "deny"
    },
    "external_directory": {
      "*": "ask",
      "~/Projects/infra/kube1/**": "allow"
    },
    "task": {
      "*": "ask"
    },
    "skill": {
      "*": "allow"
    },
    "webfetch": "allow",
    "websearch": "allow",
    "question": "allow",
    "todowrite": "allow",
    "doom_loop": "ask"
  },
  "watcher": {
    "ignore": ["graphify-out/**", "infra/ansible/.collections/**", "infra/talos/secrets/**"]
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 6
  }
}
