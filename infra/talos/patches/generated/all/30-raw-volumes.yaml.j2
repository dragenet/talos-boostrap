# Generated by render-config; do not edit.
# Layer 1 structured helper: Talos RawVolumeConfig documents for OpenEBS backing
# storage. Each storage.volumes entry with type == 'raw' produces one separate
# RawVolumeConfig config document (apiVersion: v1alpha1, kind: RawVolumeConfig),
# NOT a strategic merge into machine:.
#
# Talos provisions raw partitions from the matching disk's free space at config
# time. The partition surfaces at the stable symlink:
#   /dev/disk/by-partlabel/r-<name>
# For name: openebs-lvm → /dev/disk/by-partlabel/r-openebs-lvm
#
# Numeric prefix 30: after 25-kernel-modules (last computed fragment before user overlays).
#
# The init container in the OpenEBS node DaemonSet (Flux-side catalog at
# _components/openebs/) verifies the partlabel exists before running pvcreate/
# vgcreate. Talos only provisions the partition — it does NOT validate
# post-provisioning (the init container is the fail-loud consumer guard).
#
# No LUKS: Talos v1.13 RawVolumeConfig+LUKS has an unresolved shutdown/upgrade
# deadlock (talos#13354). The schema and validation structurally reject
# encryption keys — no encryption fields are emitted here.
#
# Gated on features.openebs — not emitted when openebs is disabled.
#
# VolumeConfig for EPHEMERAL: cap EPHEMERAL so the raw volume below has space.
# EPHEMERAL defaults to growing to fill all remaining disk space. Without a
# maxSize it claims everything before RawVolumeConfig can be provisioned.
# grow: false prevents re-expansion on subsequent boots.
# Negative maxSize: -22GiB means "leave 22 GiB free" regardless of disk size.
# On an 80 GB CX33 disk (~76.3 GiB usable after alignment): EPHEMERAL gets
# ~54 GiB, leaving ~22 GiB for the 20 GB (18.6 GiB) raw partition below.
---
apiVersion: v1alpha1
kind: VolumeConfig
name: EPHEMERAL
provisioning:
  maxSize: -22GiB
  grow: false
---
apiVersion: v1alpha1
kind: RawVolumeConfig
name: openebs-lvm
provisioning:
  diskSelector:
    match: system_disk
  minSize: 20GB
  maxSize: 20GB
