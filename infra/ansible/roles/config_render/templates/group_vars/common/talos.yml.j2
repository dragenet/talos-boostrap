{{ config_render_header }}
---
# Talos version, extensions, and working directory paths.
# Source: config/clusters/{{ config_cluster }}/cluster.yaml (talos: section)

talos_version: {{ config_render_merged.talos.version }}

# System extensions to include in the Talos image. The talos_schematic role
# resolves these into a deterministic schematic ID via factory.talos.dev.
# Adding or removing an extension here triggers a factory POST on the next run.
# Computed from: talos.extensions.base + feature-implied + talos.extensions.extra
{% if config_render_talos_extensions | length > 0 %}
talos_extensions:
{% for ext in config_render_talos_extensions %}
  - {{ ext }}
{% endfor %}
{% else %}
# Explicit empty list — stays a list (not YAML null) so consumers can iterate
# without a NoneType guard. Preserves the itemized form when populated.
talos_extensions: []
{% endif %}

# Paths to the Talos working directories. Anchored to playbook_dir, which is
# correct for playbooks at infra/ansible/playbooks/<name>.yml depth.
# The talos_schematic role is the exception — it anchors its cache path to
# role_path internally, so it works from any playbook depth.
talos_secrets_dir: "{% raw %}{{ playbook_dir }}{% endraw %}/../../talos/secrets"
talos_patches_dir: "{% raw %}{{ playbook_dir }}{% endraw %}/../../talos/patches"
