{{ config_render_header }}
---
# Cluster identity and API defaults.
# Source: config/overrides/cluster.yaml (cluster: section)

cluster_name: {{ config_render_merged.cluster.name }}
cluster_vip: {{ config_render_merged.cluster.vip }}
{% if config_render_cluster_endpoint == 'https://' ~ config_render_merged.cluster.vip ~ ':6443' %}
# Jinja expression — resolved at Ansible runtime to the VIP-based endpoint.
cluster_endpoint: '{% raw %}https://{{ cluster_vip }}:6443{% endraw %}'
{% else %}
# Explicit override of cluster.endpoint (not VIP-derived).
cluster_endpoint: {{ config_render_cluster_endpoint }}
{% endif %}
kubernetes_version: {{ config_render_merged.cluster.kubernetesVersion }}

# Extra IPs / hostnames added to TLS certificates beyond the defaults.
# Both accept a mix of IPv4, IPv6, and DNS names.
#
# cluster_talos_cert_sans  → machine.certSANs  (Talos API, port 50000, all nodes)
# cluster_k8s_cert_sans    → cluster.apiServer.certSANs (kube-apiserver, port 6443,
#                             controlplane + hybrid nodes only)
#
# Talos already includes the node's own IPs and the VIP by default. Add extras
# here when you reach the cluster through another address — e.g. a Tailscale IP,
# a Cloudflare Tunnel hostname, or an internal DNS alias.
cluster_talos_cert_sans: {{ config_render_merged.cluster.certSANs.talos | default([]) | to_yaml | trim }}
cluster_k8s_cert_sans: {{ config_render_merged.cluster.certSANs.kubernetes | default([]) | to_yaml | trim }}

# Lookup table from full node_role name → short code used only in hostnames.
# Full names are used everywhere else: Ansible groups, provider labels,
# Kubernetes node-role.kubernetes.io/* labels.
node_role_short:
{% for role, code in config_render_merged.cluster.nodeRoleShort.items() %}
  {{ role }}: {{ code }}
{% endfor %}

# All plays run locally (Talos has no SSH; cloud API calls are local too).
# ansible_playbook_python is a magic var for whatever interpreter runs
# ansible-playbook itself — portable, no hardcoded path needed.
ansible_connection: local
ansible_python_interpreter: "{% raw %}{{ ansible_playbook_python }}{% endraw %}"
