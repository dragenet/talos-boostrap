{{ config_render_header }}
---
# Hetzner Cloud provider configuration.
# Source: config/overrides/cluster.yaml (hcloud: section)
#
# hcloud.sops.yaml (encrypted token) is NOT rendered — it remains user/secret-owned.

hcloud_location: {{ config_render_merged.hcloud.location }}

# Prioritized server type lists — first type available in hcloud_location wins.
# Hetzner occasionally sells out specific types in a location; the fallback
# ensures provisioning succeeds without manual intervention.
#
# hcloud_server_types       — default for all node roles
# hcloud_server_types_per_role — optional per-role override (falls back to the
#                                default list for any role not listed here)
# hcloud_builder_server_types — for the temporary snapshot builder only;
#                               something small is fine, it just dd's an image
hcloud_server_types: {{ config_render_merged.hcloud.serverTypes | to_yaml | trim }}
hcloud_server_types_per_role: {{ config_render_merged.hcloud.serverTypesPerRole | default({}) | to_yaml | trim }}
hcloud_builder_server_types: {{ config_render_merged.hcloud.builderServerTypes | to_yaml | trim }}

# hcloud_talos_image is NOT set here — it is resolved at runtime by
# provision-infra.yml, which queries Hetzner for a snapshot whose labels match
# the current talos_version + talos_schematic_id. Run image-talos.yml first
# to build one if none exists.
hcloud_private_network_name: {{ config_render_merged.hcloud.privateNetworkName }}
hcloud_private_network_cidr: {{ config_render_merged.hcloud.privateNetworkCidr }}
hcloud_private_subnet_cidr: {{ config_render_merged.hcloud.privateSubnetCidr }}
hcloud_firewall_name: {{ config_render_merged.hcloud.firewallName }}

# SSH key registered in Hetzner Cloud — used only during image build (rescue mode).
hcloud_ssh_key_name: '{{ config_render_merged.hcloud.sshKeyName }}'

# ─── Admin access mode ─────────────────────────────────────────────────────────
#
# hcloud_firewall_open_access: false (default)
#   Scopes the Talos API (50000) and Kubernetes API (6443) rules to admin IPs.
#   hcloud_admin_ips below controls which IPs are allowed:
#     []             → auto-detect YOUR CURRENT public IP via ifconfig.me at
#                      provision time and firewall to that /32.
#                      !! LOCK-OUT RISK: if your IP changes later the OLD IP
#                      stays whitelisted — you silently lose access. Talos has
#                      no SSH fallback. Set a stable range when you have one.
#     ["1.2.3.4/32"] → pin specific CIDRs (recommended once you have a stable IP)
#
# hcloud_firewall_open_access: true
#   Opens port 50000 and 6443 to 0.0.0.0/0 + ::/0 (the whole internet).
#   Use when your public IP is dynamic and frequently changes. The ports are
#   still mTLS/cert-authenticated (talosctl / kubectl) — "open" only widens
#   network reach, it does not disable auth. That said, it does expose endpoints
#   to internet-wide scanning, so prefer the admin-IP mode when your IP is stable.
#
hcloud_firewall_open_access: {{ config_render_merged.hcloud.firewallOpenAccess | lower }}
hcloud_admin_ips: {{ config_render_merged.hcloud.adminIps | default([]) | to_yaml | trim }}

# How many nodes of each role to provision. Names are derived automatically:
# {{ '{{' }} cluster_name {{ '}}' }}-{{ '{{' }} node_role_short[role] {{ '}}' }}{{ '{{' }} n {{ '}}' }}
# Private IPs are assigned deterministically from the subnet base + index,
# ordered: controlplane nodes first, then hybrid, then worker.
# Current cluster: 3 hybrid nodes (kube1-hb1 → 10.0.0.11, etc.)
hcloud_topology:
{% for role, count in config_render_merged.hcloud.topology.items() %}
  {{ role }}: {{ count }}
{% endfor %}

# Starting octet for node private IPs within hcloud_private_subnet_cidr.
# Layout of 10.0.0.0/24:
#   .0  — network address
#   .1  — Hetzner gateway
#   .10 — cluster VIP (cluster_vip in inventories/common/group_vars/all/cluster.yml)
#   .11+ — nodes, assigned sequentially: controlplane → hybrid → worker
# hcloud_servers_ip_offset (11) is the first usable node address, deliberately
# placed past the VIP so node IPs never collide with the floating VIP.
hcloud_servers_ip_offset: {{ config_render_merged.hcloud.serversIpOffset }}

# ─── Bootstrap pre-Flux components ────────────────────────────────────────────
#
# Provider-keyed list of components installed by bootstrap-flux.yml before
# Flux reconciliation starts (ADR-010). Computed from features + provider.
{% if config_render_bootstrap_pre_flux_components | length > 0 %}
bootstrap_pre_flux_components:
{% for component in config_render_bootstrap_pre_flux_components %}
  - {{ component }}
{% endfor %}
{% else %}
# Explicit empty list — stays a list (not YAML null) so bootstrap-flux.yml can
# iterate without a NoneType guard. Occurs when features.cni: none.
bootstrap_pre_flux_components: []
{% endif %}
