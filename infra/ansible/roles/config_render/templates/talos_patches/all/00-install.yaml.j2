{{ config_render_header }}
---
# Layer 1 structured helper: machine install image + optional Talos API SANs.
# Source: talos.version + talos.extensions (resolved to schematic at bootstrap time)
# Extended by: cluster.certSANs.talos
#
# talos_installer_image is resolved at bootstrap time by the talos_schematic role
# from talos_extensions + talos_version via factory.talos.dev — it cannot be
# baked in at render time.
#
# Replaces the pre-refactor infra/talos/patches/common.yaml.j2.
machine:
  install:
    image: {% raw %}{{ talos_installer_image }}{% endraw %}
{% if config_render_merged.cluster.certSANs.talos | default([]) | length > 0 %}
  # Extra SANs for the Talos API certificate (port 50000).
  # Talos already adds the node's own IPs; list here anything additional
  # (Tailscale IPs, DNS aliases) you use to reach talosctl from outside.
  certSANs:
{% for san in config_render_merged.cluster.certSANs.talos %}
    - {{ san }}
{% endfor %}
{% endif %}
