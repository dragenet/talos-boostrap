# Layer 1 structured helper: enable external cloud provider for hcloud CCM.
# Source: computed from provider.name + features.cni (via bootstrap_pre_flux_components)
#
# When hcloud CCM is selected (provider.name == 'hcloud' + features.cni == 'cilium'
# today), Talos must run kubelet and kube-controller-manager with
# --cloud-provider=external so the hcloud Cloud Controller Manager can
# initialise nodes: set spec.providerID, clear the
# node.cloudprovider.kubernetes.io/uninitialized taint, and attach
# topology/region labels. Without this flag the CCM cannot manage nodes and
# they stay tainted (NoSchedule) forever.
#
# Applied to ALL node roles (controlplane + hybrid + worker) via --config-patch
# because every node's kubelet needs the external-provider flag — not just
# control-plane. Per the Talos Hetzner guide this patch is applied to every
# node IP, not only the control-plane set.
#
# Manual/bare-metal inventories never emit this patch: there is no CCM to clear
# the uninitialized taint, so enabling externalCloudProvider there would
# permanently taint nodes and block workload scheduling.
#
# Talos docs state this field sets --cloud-provider=external on kubelet and
# kube-controller-manager; do not add raw component extraArgs unless the docs
# change.
cluster:
  externalCloudProvider:
    enabled: true
