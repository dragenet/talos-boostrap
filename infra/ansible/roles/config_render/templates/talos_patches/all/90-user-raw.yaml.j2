{{ config_render_header }}
---
# Layer 2 raw fragments: cluster-wide patches applied to all node types.
# Source: talos.patches.all (cluster.yaml)
#
# Each list entry is a verbatim Talos YAML fragment. All fragments are
# concatenated into this single file, which is passed as one --config-patch
# to talosctl gen config.
#
# Talos constraint: a single patch file cannot modify the same document more
# than once. If you need multiple patches to the same config document, combine
# them into one fragment. For patches targeting different config documents
# (e.g. HostnameConfig, TimeConfig), separate fragments are fine.
{% for fragment in config_render_merged.talos.patches.all %}
{{ fragment | indent(0, first=false) }}
{% endfor %}
