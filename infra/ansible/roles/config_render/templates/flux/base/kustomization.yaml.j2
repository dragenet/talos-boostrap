{{ config_render_header }}
# This kustomization is render-owned. The render compiler populates resources:
# with the enabled catalog entries from _components/ based on cluster.yaml
# features and provider selection (ADR-010, ADR-012).
apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization
{% if config_render_flux_base_resources | length > 0 %}
resources:
  - {{ config_render_flux_base_resources | join("\n  - ") }}
{% else %}
resources: []
{% endif %}
